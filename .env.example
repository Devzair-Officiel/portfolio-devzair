# ─── Domaines (Caddy — non utilisé en mode Apache reverse proxy) ──────────────
CADDY_DOMAIN=devzair.fr
CADDY_API_DOMAIN=api-portfolio.devzair.fr
CADDY_EMAIL=ton@email.fr

# URL publique de l'API (injectée dans le build React par Vite)
VITE_API_URL=https://api-portfolio.devzair.fr

# ─── Base de données ───────────────────────────────────────────────────────────
DB_USER=devzair
DB_PASSWORD=change_me_strong_password
DB_NAME=devzair_db
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://devzair:change_me_strong_password@db:5432/devzair_db

# ─── API FastAPI ───────────────────────────────────────────────────────────────
APP_ENV=production
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_strong_secret

# CORS — domaine autorisé à appeler l'API
ALLOWED_ORIGINS=["https://devzair.fr", "http://localhost:5173"]

# ─── Email OVH ────────────────────────────────────────────────────────────────
MAIL_USERNAME=contact@devzair.fr
MAIL_PASSWORD=ton_mot_de_passe_mail
MAIL_FROM=contact@devzair.fr
MAIL_SERVER=ssl0.ovh.net
MAIL_PORT=465
MAIL_SSL_TLS=true
MAIL_STARTTLS=false
